<UserControl x:Class="POS_WPF.Pages.ModelPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#f7f7fb"
             Loaded="UserControl_Loaded"
             SizeChanged="UserControl_SizeChanged">

    

    <Grid Margin="20 ,0 ,0 ,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="35.95"/>
            <RowDefinition Height="33.05"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER: Icon + Title + Add Button -->
        <DockPanel Grid.Row="0" Margin="0,20,20,20" LastChildFill="False">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                <!-- ICON -->
                <Viewbox Width="26" Height="26" Margin="0,0,10,0">
                    <Path Fill="#FF8C42" Stretch="Uniform"
                          Data="M26 30H42a2 2 0 0 0 2-2V20a2 2 0 0 0-2-2H26a2 2 0 0 0-2 2v2H16V14h6a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H6A2 2 0 0 0 4 4v8a2 2 0 0 0 2 2h6V40a2 2 0 0 0 2 2H24v2a2 2 0 0 0 2 2H42a2 2 0 0 0 2-2V36a2 2 0 0 0-2-2H26a2 2 0 0 0-2 2v2H16V26h8v2a2 2 0 0 0 2 2Z"/>
                </Viewbox>

                <TextBlock x:Name="txtTitle" Text="Model Management" FontSize="26" FontWeight="Bold" Foreground="#4A4A4A" VerticalAlignment="Center"/>
            </StackPanel>

            <Button Style="{StaticResource IconActionBtn}" Width="160" DockPanel.Dock="Right" Click="BtnAddModel_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M12 5 L12 19 M5 12 L19 12"/>
                        </Canvas>
                    </Viewbox>

                    <TextBlock Grid.Column="1" Text="Add Model" VerticalAlignment="Center" FontSize="14"/>
                </Grid>
            </Button>
        </DockPanel>

        <!-- SEARCH + WAREHOUSE FILTER -->
        <Grid Grid.Row="1"  VerticalAlignment="Top" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="240"/>
            </Grid.ColumnDefinitions>

            <!-- SEARCH BOX -->
            <Grid Grid.Column="0" Height="65">
                <Border CornerRadius="12" Background="White" BorderBrush="#CED6E0" BorderThickness="1"/>
                <TextBox x:Name="txtSearch" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"
                         FontSize="14" Padding="35,0,5,0" Foreground="#2F3640" TextChanged="txtSearch_TextChanged"/>
                <TextBlock x:Name="txtPlaceholder" Text=" Search model..." Foreground="#A4B0BE"
                           VerticalAlignment="Center" FontSize="16" Margin="35,0,5,0" IsHitTestVisible="False"/>
                <TextBlock Text="🔍" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" FontSize="16" Foreground="#57606f"/>
            </Grid>

            <!-- WAREHOUSE COMBOBOX -->
            <StackPanel Grid.Column="2" Margin="0,0,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                <TextBlock Text="Select Warehouse" FontSize="16" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbWarehouse" Style="{StaticResource ModernComboBox}" ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                          Width="220" HorizontalAlignment="Stretch" VerticalAlignment="Center" SelectedIndex="0"
                          Cursor="Hand" SelectionChanged="cmbWarehouse_SelectionChanged"
                          PreviewMouseLeftButtonDown="cmbWarehouse_PreviewMouseLeftButtonDown"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3">
            <!-- Cards ScrollViewer -->
            <ScrollViewer x:Name="CardScrollViewer"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    PanningMode="VerticalOnly"
                    ClipToBounds="True">

                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="1"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="{TemplateBinding Background}">
                                        <Track x:Name="PART_Track"
                     IsDirectionReversed="True">
                                            <Track.Thumb>
                                                <Thumb x:Name="Thumb">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Rectangle Fill="#9CA3AF" RadiusX="3" RadiusY="3"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Thumb" Property="Opacity" Value="1"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="False">
                                            <Setter TargetName="Thumb" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>

                <Grid>
                    <!-- Cards container -->
                    <ItemsControl x:Name="DynamicCardContainer">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel x:Name="WrapPanelContainer" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <!-- No products message -->
                    <TextBlock x:Name="NoModelsMessage"
                                  Foreground="Gray"
                                  FontSize="18"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed"/>
                </Grid>

            </ScrollViewer>

            <!-- Sweet Loading Overlay for WPF -->
            <Grid x:Name="LoadingOverlay"
                  Background="#F5F5F5"
                  Visibility="Collapsed">

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Circular Spinner with small gap -->
                    <Grid Width="80" Height="80">
                        <!-- Background circle -->
                        <Ellipse Width="60" Height="60" 
                               Stroke="#E0E0E0" 
                               StrokeThickness="6"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                        <!-- Rotating Arc using Path -->
                        <Viewbox Width="60" Height="60">
                            <Canvas Width="100" Height="100">
                                <Path Stroke="#4A4A4A" 
                                    StrokeThickness="10"
                                    StrokeStartLineCap="Round"
                                    StrokeEndLineCap="Round">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="50,10">
                                                <ArcSegment Point="10,50" 
                                            Size="40,40" 
                                            SweepDirection="Clockwise"
                                            IsLargeArc="True"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotate" CenterX="50" CenterY="50" Angle="0"/>
                                    </Path.RenderTransform>
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Path.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                               Storyboard.TargetProperty="Angle"
                                                               From="0" 
                                                               To="360"
                                                               Duration="0:0:0.8"
                                                               RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Grid>

                    <TextBlock Text="Loading warehouses..." 
                             Foreground="#4A4A4A" 
                             FontWeight="SemiBold" 
                             FontSize="14" 
                             Margin="0,20,0,0" 
                             HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

        </Grid>

        <!-- TOTAL MODELS -->
        <Border Grid.Row="4" 
                Margin="0,10,10,10" 
                Background="White" 
                CornerRadius="8" 
                Padding="12" 
                HorizontalAlignment="Left" 
                VerticalAlignment="Center" 
                Effect="{StaticResource DropShadow}">
            <TextBlock x:Name="txtTotalModels" 
                       Text="Total Models: 0" 
                       FontSize="16" 
                       FontWeight="SemiBold" 
                       Foreground="#2C3E50"/>
        </Border>

    </Grid>
    
    
</UserControl>
