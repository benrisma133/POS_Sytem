<Window x:Class="POS_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:POS_WPF.Pages"
        Title="POS System" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#f7f7fb">

    <Window.Resources>
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Background" Value="#A29BFE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ColSidebar" Width="220" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Background="#6C5CE7" Grid.Column="0">
            <StackPanel Margin="10">

                <Button Content="☰"
                        Background="Transparent"
                        Foreground="White"
                        FontSize="22"
                        BorderBrush="Transparent"
                        HorizontalAlignment="Left"
                        Click="ToggleMenu_Click"/>

                <StackPanel Margin="0,20,0,0">

                    <Button Style="{StaticResource MenuBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Dashboard"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛒" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="New Sale"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Products"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Reports"/>
                        </StackPanel>
                    </Button>

                    <!-- WAREHOUSE BUTTON -->
                    <Button Style="{StaticResource MenuBtn}" Click="Warehouse_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏭" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Warehouse"/>
                        </StackPanel>
                    </Button>

                    <!-- WAREHOUSE / CATEGORY BUTTON FIXED -->
                    <Button Style="{StaticResource MenuBtn}"
        Click="Warehouse_Click"
        Margin="0,6,0,6">
                        <!-- optional: same as MenuBtn style -->

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ICON -->
                            <Viewbox Width="22"
                 Height="22"
                 Margin="0,0,12,0"
                 VerticalAlignment="Center">
                                <Canvas Width="48" Height="48">
                                    <Rectangle Canvas.Left="6"
                           Canvas.Top="28"
                           Width="36"
                           Height="14"
                           RadiusX="4"
                           RadiusY="4"
                           Stroke="Black"
                           StrokeThickness="4"/>

                                    <Path Data="M20 7 H10 C7.8 7 6 8.8 6 11 V17 C6 19.2 7.8 21 10 21 H20"
                      Stroke="Black"
                      StrokeThickness="4"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Fill="Transparent"/>

                                    <Ellipse Canvas.Left="26"
                         Canvas.Top="6"
                         Width="16"
                         Height="16"
                         Fill="#2F88FF"
                         Stroke="Black"
                         StrokeThickness="4"/>

                                    <Ellipse Canvas.Left="31"
                         Canvas.Top="11"
                         Width="6"
                         Height="6"
                         Fill="White"/>
                                </Canvas>
                            </Viewbox>

                            <!-- TEXT -->
                            <TextBlock Grid.Column="1"
                   Text="Categories"
                   VerticalAlignment="Center"
                   FontSize="16"/>
                        </Grid>
                    </Button>




                    <Button Style="{StaticResource MenuBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Settings"/>
                        </StackPanel>
                    </Button>
                    
                    

                </StackPanel>
            </StackPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1" x:Name="MainContent" Background="#f7f7fb">
            <TextBlock Text="Welcome to POS System"
                       FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#2d3436"/>
            
        </Grid>
        
        

    </Grid>
</Window>
