<Window x:Class="POS_WPF.Product.frmTransferProduct"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:POS_WPF.Controls"
        Title="Transfer Product"
        Width="540"
        Height="480"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Loaded="Window_Loaded">

    <Window.Resources>

        <Style x:Key="MessageBox" TargetType="Border">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="ErrorBox" TargetType="Border" BasedOn="{StaticResource MessageBox}">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="BorderBrush" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SuccessBox" TargetType="Border" BasedOn="{StaticResource MessageBox}">
            <Setter Property="Background" Value="#D1FAE5"/>
            <Setter Property="BorderBrush" Value="#10B981"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F2F4F8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E1E5EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C9D1DC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconStyle" TargetType="Path">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Fill" Value="#4A4A4A"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <Style x:Key="SweetButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#888"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="8">
        <Border CornerRadius="16"
                Background="White"
                BorderBrush="#DDE1E8"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="55"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border CornerRadius="16,16,0,0" Background="#5E5E5E" Grid.Row="0" MouseDown="Header_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                            <!-- Transfer / arrows icon -->
                            <Path Width="22" Height="22" Stretch="Uniform" Fill="#FF8C42"
                                  Data="M7.5 21L3 16.5m0 0L7.5 12M3 16.5H21M16.5 3L21 7.5m0 0L16.5 12M21 7.5H3"/>

                            <TextBlock Margin="10,0,0,0"
                                       Text="Transfer Product"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#F5F5F5"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButtonStyle}"
                                Click="Close_Click"
                                Margin="6,10">
                            <Path Style="{StaticResource IconStyle}"
                                  Fill="#FF8C42"
                                  Data="M18.3 5.71L12 12l6.3 6.29-1.41 1.42L10.59 13.4l-6.3 6.31-1.41-1.42L9.17 12 2.88 5.71l1.41-1.42 6.3 6.3 6.29-6.3z"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel Margin="40,25,40,0">

                        <TextBlock Text="Transfer Product"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Move stock between warehouses"
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   Margin="0,0,0,30"/>

                        <!-- Error Box -->
                        <Border x:Name="ErrorMessageBox"
                                Style="{StaticResource ErrorBox}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Foreground="#DC2626" FontSize="14" Margin="0,0,0,6">
                                    ⚠️ Please fix the following errors:
                                </TextBlock>
                                <TextBlock x:Name="ErrorMessageText"
                                           Foreground="#991B1B"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Success Box -->
                        <Border x:Name="SuccessMessageBox"
                                Style="{StaticResource SuccessBox}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Foreground="#059669" FontSize="14" Margin="0,0,0,6">
                                    ✓ Transfer Successful!
                                </TextBlock>
                                <TextBlock Text="The product has been transferred successfully."
                                           Foreground="#047857"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- From Warehouse -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="From Warehouse"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#2C3E50"
                                       Margin="0,0,0,6"/>
                            <ComboBox x:Name="cmbFromWarehouse"
                                      Style="{StaticResource ModernComboBox}"
                                      ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                                      Width="260"
                                      HorizontalAlignment="Left"
                                      Cursor="Hand"
                                      SelectedIndex="0"
                                      SelectionChanged="cmbFromWarehouse_SelectionChanged"/>
                        </StackPanel>

                        <!-- Arrow indicator -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#FFF3E8"
                                    CornerRadius="50"
                                    Width="36" Height="36">
                                <Path Width="18" Height="18"
                                      Stretch="Uniform"
                                      Fill="#FF8C42"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M12 4L12 20M12 20L6 14M12 20L18 14"/>
                            </Border>
                            <TextBlock Text="transferring to"
                                       FontSize="13"
                                       Foreground="#9CA3AF"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       FontStyle="Italic"/>
                        </StackPanel>

                        <!-- To Warehouse -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="To Warehouse"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#2C3E50"
                                       Margin="0,0,0,6"/>
                            <ComboBox x:Name="cmbToWarehouse"
                                      Style="{StaticResource ModernComboBox}"
                                      ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                                      Width="260"
                                      HorizontalAlignment="Left"
                                      Cursor="Hand"
                                      SelectedIndex="0"
                                      SelectionChanged="cmbToWarehouse_SelectionChanged"/>
                        </StackPanel>

                        <!-- Quantity -->
                        <controls:ModernInput x:Name="TransferQuantity"
                                              Label="Quantity to Transfer"
                                              Placeholder="Enter quantity"
                                              IsRequired="True"
                                              ValidationType="Numeric"
                                              BorderRadius="20"
                                              MinLength="1"
                                              Margin="0,0,0,20"/>

                        <!-- Available stock hint -->
                        <TextBlock x:Name="txtAvailableStock"
                                   FontSize="13"
                                   Foreground="#6B7280"
                                   Margin="4,0,0,20"
                                   Visibility="Collapsed">
                            <!-- Populated from code-behind e.g. "Available: 42 units" -->
                        </TextBlock>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer Buttons -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,20,0">

                    <!-- Cancel -->
                    <Button Width="130" Height="42"
                            Background="#5E5E5E"
                            Style="{StaticResource SweetButton}"
                            Click="Cancel_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Style="{StaticResource IconStyle}" Fill="White"
                                  Data="M16 29c-7.18 0-13-5.82-13-13s5.82-13 13-13 13 5.82 13 13-5.82 13-13 13zM16 6c-5.522 0-10 4.478-10 10s4.478 10 10 10c5.523 0 10-4.478 10-10s-4.477-10-10-10zM20.537 19.535l-1.014 1.014c-0.186 0.186-0.488 0.186-0.675 0l-2.87-2.87-2.87 2.87c-0.187 0.186-0.488 0.186-0.675 0l-1.014-1.014c-0.186-0.186-0.186-0.488 0-0.675l2.871-2.869-2.871-2.87c-0.186-0.187-0.186-0.489 0-0.676l1.014-1.013c0.187-0.187 0.488-0.187 0.675 0l2.87 2.87 2.87-2.87c0.187-0.187 0.489-0.187 0.675 0l1.014 1.013c0.186 0.187 0.186 0.489 0 0.676l-2.871 2.87 2.871 2.869c0.186 0.187 0.186 0.49 0 0.675z"/>
                            <TextBlock Text="Cancel" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Transfer -->
                    <Button Width="130" Height="42"
                            Background="#FF8C42"
                            Margin="10,0,0,0"
                            Style="{StaticResource SweetButton}"
                            Click="Transfer_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- swap/transfer icon -->
                            <Path Style="{StaticResource IconStyle}" Fill="White"
                                  Data="M7.5 21L3 16.5m0 0L7.5 12M3 16.5H21M16.5 3L21 7.5m0 0L16.5 12M21 7.5H3"/>
                            <TextBlock Text="Transfer" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>